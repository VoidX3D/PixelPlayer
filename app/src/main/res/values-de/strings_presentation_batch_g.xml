    <string name="presentation_batch_g_beta_sheet_welcome_title">Willkommen bei PixelPlayer 0.6.0-beta</string>
    <string name="presentation_batch_g_beta_sheet_welcome_body">Diese Beta konzentriert sich nun auf Stabilität, Leistung und geräteübergreifende Wiedergabe, während wichtige neue Integrationen eingeführt werden.</string>
